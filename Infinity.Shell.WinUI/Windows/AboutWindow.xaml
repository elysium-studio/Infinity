<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Infinity.Shell.WinUI.AboutWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TitleBar x:Name="AppTitleBar" Title="About">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="ms-appx:///Assets/Infinity.png" />
            </TitleBar.IconSource>
        </TitleBar>
        <Grid
            Grid.Row="1"
            Margin="24"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="24" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="24" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Image
                Grid.Row="0"
                Width="120"
                Height="120"
                HorizontalAlignment="Center"
                Source="ms-appx:///Assets/Infinity.png" />
            <TextBlock
                Grid.Row="2"
                HorizontalAlignment="Center"
                FontSize="22"
                FontWeight="SemiBold"
                Text="{x:Bind ViewModel.Title}" />
            <TextBlock
                Grid.Row="4"
                HorizontalAlignment="Center"
                FontSize="13"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{x:Bind ViewModel.Version}" />
            <TextBlock
                Grid.Row="6"
                HorizontalAlignment="Center"
                FontSize="13"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{x:Bind ViewModel.Copyright}" />
            <HyperlinkButton
                Grid.Row="8"
                HorizontalAlignment="Center"
                Content="elysiumstud.io"
                NavigateUri="{x:Bind ViewModel.WebsiteUri}" />
        </Grid>
    </Grid>
</Window>