<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Infinity.Shell.WinUI.TourWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:WinUI="using:Elysium.UI.WinUI">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>
    <Grid>
        <TitleBar
            x:Name="AppTitleBar"
            Title="Getting Started"
            VerticalAlignment="Top">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="ms-appx:///Assets/Infinity.png" />
            </TitleBar.IconSource>
        </TitleBar>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <ScrollViewer
                Grid.Row="0"
                Background="{ThemeResource LayerOnAcrylicFillColorDefault}"
                HorizontalScrollMode="Disabled"
                VerticalScrollBarVisibility="Auto">
                <Grid Padding="48,48,48,48">
                    <ContentControl
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Content="{x:Bind ViewModel.CurrentStep, Mode=OneWay}"
                        ContentTemplateSelector="{WinUI:ViewTemplateSelector}" />
                    <PipsPager
                        Grid.Column="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        NextButtonVisibility="Collapsed"
                        NumberOfPages="{x:Bind ViewModel.Count, Mode=OneTime}"
                        PreviousButtonVisibility="Collapsed"
                        SelectedPageIndex="{x:Bind ViewModel.SelectedIndex, Mode=TwoWay}" />
                </Grid>
            </ScrollViewer>
            <Border
                Grid.Row="1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
                <Grid Padding="24,16" ColumnDefinitions="*,Auto">
                    <StackPanel
                        Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8">
                        <Button
                            x:Name="BackButton"
                            MinWidth="132"
                            Click="{x:Bind ViewModel.GoBack}"
                            Content="Back"
                            IsEnabled="{x:Bind ViewModel.CanGoBack, Mode=OneWay}" />
                        <Grid>
                            <Button
                                x:Name="NextButton"
                                MinWidth="132"
                                Click="{x:Bind ViewModel.GoNext}"
                                Content="Next"
                                IsEnabled="{x:Bind ViewModel.CanGoNext, Mode=OneWay}"
                                Style="{StaticResource AccentButtonStyle}"
                                Visibility="{x:Bind ToNextVisibility(ViewModel.IsLastStep), Mode=OneWay}" />
                            <Button
                                x:Name="FinishButton"
                                MinWidth="132"
                                Click="{x:Bind ViewModel.Finish}"
                                Content="Finish"
                                Style="{StaticResource AccentButtonStyle}"
                                Visibility="{x:Bind ToFinishVisibility(ViewModel.IsLastStep), Mode=OneWay}" />
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>