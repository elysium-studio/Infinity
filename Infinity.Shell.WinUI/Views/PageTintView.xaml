<?xml version="1.0" encoding="utf-8" ?>
<Controls:DesktopOverlay
    x:Class="Infinity.Shell.WinUI.PageTintView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="using:Elysium.UI.Controls.WinUI"
    xmlns:WinUI="using:Elysium.UI.WinUI"
    DataContext="{WinUI:ViewModel Key=PageTintView}"
    HeaderPlacement="{x:Bind ToHeaderPlacement(ViewModel.PreviewPosition), Mode=OneWay}"
    IsBlurEnabled="{x:Bind ViewModel.IsBlurEnabled, Mode=TwoWay}"
    IsOpen="{x:Bind ViewModel.IsOpen, Mode=TwoWay}"
    Loaded="{x:Bind ViewModel.Activated}"
    StaysOpen="{x:Bind ViewModel.StaysOpen, Mode=TwoWay}">
    <Controls:DesktopOverlay.Header>
        <Grid x:Name="ShadowContainer">
            <Canvas x:Name="ShadowCanvas" />
            <Border
                Width="240"
                Margin="18"
                BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource OverlayCornerRadius}">
                <Grid>
                    <SystemBackdropElement CornerRadius="{StaticResource OverlayCornerRadius}">
                        <SystemBackdropElement.SystemBackdrop>
                            <Controls:ActiveDesktopAcrylicBackdrop />
                        </SystemBackdropElement.SystemBackdrop>
                    </SystemBackdropElement>
                    <Grid>
                        <TextBlock
                            Margin="-24,0,0,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            Text="{x:Bind ViewModel.PageTitle, Mode=OneWay}"
                            Visibility="{x:Bind ToInverseVisibility(ViewModel.IsEditing), Mode=OneWay}" />
                        <TextBox
                            x:Name="TitleTextBox"
                            Margin="8,0,52,0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            Text="{x:Bind ViewModel.EditingTitle, Mode=TwoWay}"
                            Visibility="{x:Bind ToVisibility(ViewModel.IsEditing), Mode=OneWay}" />
                        <StackPanel
                            Margin="4"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                            <Rectangle
                                Width="1"
                                Margin="4"
                                VerticalAlignment="Stretch"
                                Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                            <Button
                                Width="36"
                                Height="36"
                                Padding="0"
                                Click="{x:Bind ViewModel.BeginEditing}"
                                Visibility="{x:Bind ToInverseVisibility(ViewModel.IsEditing), Mode=OneWay}">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonBackground" Color="Transparent" />
                                    <SolidColorBrush x:Key="ButtonBorderBrush" Color="Transparent" />
                                </Button.Resources>
                                <FontIcon FontSize="16" Glyph="&#xE70F;" />
                            </Button>
                            <Button
                                Width="36"
                                Height="36"
                                Padding="0"
                                Click="{x:Bind ViewModel.CommitEditAsync}"
                                Visibility="{x:Bind ToVisibility(ViewModel.IsEditing), Mode=OneWay}">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonBackground" Color="Transparent" />
                                    <SolidColorBrush x:Key="ButtonBorderBrush" Color="Transparent" />
                                </Button.Resources>
                                <FontIcon FontSize="16" Glyph="&#xE74E;" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Controls:DesktopOverlay.Header>
</Controls:DesktopOverlay>