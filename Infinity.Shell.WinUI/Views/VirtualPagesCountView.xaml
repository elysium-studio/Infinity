<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Infinity.Shell.WinUI.VirtualPagesCountView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:CommunityToolkit="using:CommunityToolkit.WinUI.Controls"
    Loaded="{x:Bind ViewModel.Activate}"
    Unloaded="{x:Bind ViewModel.Deactivate}">
    <CommunityToolkit:SettingsCard
        Description="Set the maximum number of pages"
        Header="Number of Pages"
        IsEnabled="{x:Bind ViewModel.IsEnabled, Mode=OneWay}">
        <NumberBox
            LargeChange="5"
            Maximum="999"
            Minimum="2"
            SmallChange="1"
            SpinButtonPlacementMode="Hidden"
            Value="{x:Bind ViewModel.Value, Mode=TwoWay}" />
    </CommunityToolkit:SettingsCard>
</UserControl>