<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Infinity.Shell.WinUI.DragScrollSpeedView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:CommunityToolkit="using:CommunityToolkit.WinUI.Controls"
    Loaded="{x:Bind ViewModel.Activate}">
    <CommunityToolkit:SettingsCard Description="How fast the desktop scrolls when dragging a window to the screen edge" Header="Drag Scroll Speed">
        <ComboBox SelectedIndex="{x:Bind ViewModel.Value, Mode=TwoWay}">
            <ComboBoxItem Content="Slow" />
            <ComboBoxItem Content="Normal" />
            <ComboBoxItem Content="Fast" />
            <ComboBoxItem Content="Turbo" />
        </ComboBox>
    </CommunityToolkit:SettingsCard>
</UserControl>