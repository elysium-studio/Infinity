<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Infinity.Shell.WinUI.WindowNumberTriggerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:WinUI="using:Elysium.UI.WinUI"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    HorizontalContentAlignment="Center"
    VerticalContentAlignment="Top"
    DataContext="{WinUI:ViewModel Key=WindowNumberTriggerView}"
    Loaded="{x:Bind ViewModel.Activate}"
    Unloaded="{x:Bind ViewModel.Deactivate}">
    <StackPanel
        MaxWidth="600"
        HorizontalAlignment="Center"
        Spacing="28">
        <Border
            x:Name="HeroCard"
            Height="240"
            HorizontalAlignment="Stretch"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="14">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="28">
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Vertical"
                    Spacing="16">
                    <StackPanel
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="14">
                        <Grid
                            x:Name="WinKeyCard"
                            Width="64"
                            Height="64">
                            <Border
                                Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                                BorderThickness="1.5"
                                CornerRadius="12" />
                            <Border
                                x:Name="WinKeyAccentOverlay"
                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                CornerRadius="12"
                                Opacity="0" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                Text="{x:Bind ViewModel.FirstModifier, Mode=OneWay}" />
                        </Grid>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="+" />
                        <Grid
                            x:Name="CtrlKeyCard"
                            Width="64"
                            Height="64">
                            <Border
                                Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                                BorderThickness="1.5"
                                CornerRadius="12" />
                            <Border
                                x:Name="CtrlKeyAccentOverlay"
                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                CornerRadius="12"
                                Opacity="0" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                Text="{x:Bind ViewModel.SecondModifier, Mode=OneWay}" />
                        </Grid>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="+" />
                        <Grid
                            x:Name="ShiftKeyCard"
                            Width="64"
                            Height="64">
                            <Border
                                Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                                BorderThickness="1.5"
                                CornerRadius="12" />
                            <Border
                                x:Name="ShiftKeyAccentOverlay"
                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                CornerRadius="12"
                                Opacity="0" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                Text="Shift" />
                        </Grid>
                    </StackPanel>
                    <Grid
                        x:Name="NumberKeyCard"
                        Width="64"
                        Height="64"
                        HorizontalAlignment="Center">
                        <Border
                            Background="{ThemeResource ControlFillColorSecondaryBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                            BorderThickness="1.5"
                            CornerRadius="12" />
                        <Border
                            x:Name="NumberKeyAccentOverlay"
                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                            CornerRadius="12"
                            Opacity="0" />
                        <TextBlock
                            x:Name="NumberDigitText"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="20"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                            Text="1" />
                    </Grid>
                </StackPanel>
                <Border
                    Width="1"
                    Height="170"
                    VerticalAlignment="Center"
                    Background="{ThemeResource ControlStrokeColorSecondaryBrush}"
                    Opacity="0.6" />
                <Grid
                    x:Name="JumpStage"
                    Width="230"
                    Height="110"
                    VerticalAlignment="Center">
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Orientation="Horizontal"
                        Spacing="8">
                        <StackPanel
                            HorizontalAlignment="Center"
                            Orientation="Vertical"
                            Spacing="4">
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="11"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                Text="1" />
                            <Border
                                Width="70"
                                Height="70"
                                Background="{ThemeResource ControlFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                                BorderThickness="1"
                                CornerRadius="10" />
                        </StackPanel>
                        <StackPanel
                            HorizontalAlignment="Center"
                            Orientation="Vertical"
                            Spacing="4">
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="11"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                Text="2" />
                            <Border
                                Width="70"
                                Height="70"
                                Background="{ThemeResource ControlFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                                BorderThickness="1"
                                CornerRadius="10" />
                        </StackPanel>
                        <StackPanel
                            HorizontalAlignment="Center"
                            Orientation="Vertical"
                            Spacing="4">
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="11"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                Text="3" />
                            <Border
                                Width="70"
                                Height="70"
                                Background="{ThemeResource ControlFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                                BorderThickness="1"
                                CornerRadius="10" />
                        </StackPanel>
                    </StackPanel>
                    <Line
                        Stroke="{ThemeResource ControlStrokeColorSecondaryBrush}"
                        StrokeDashArray="2,2"
                        StrokeThickness="1"
                        X1="76"
                        X2="76"
                        Y1="22"
                        Y2="96" />
                    <Line
                        Stroke="{ThemeResource ControlStrokeColorSecondaryBrush}"
                        StrokeDashArray="2,2"
                        StrokeThickness="1"
                        X1="154"
                        X2="154"
                        Y1="22"
                        Y2="96" />
                    <Border
                        x:Name="JumpWindow"
                        Width="52"
                        Height="44"
                        Margin="14,32,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                        BorderThickness="1.5"
                        CornerRadius="8">
                        <Grid>
                            <Border
                                x:Name="JumpWindowTitlebar"
                                Height="14"
                                VerticalAlignment="Top"
                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                CornerRadius="8,8,0,0"
                                Opacity="0.55" />
                        </Grid>
                    </Border>
                    <StackPanel
                        Margin="0,0,0,2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Orientation="Horizontal"
                        Spacing="6">
                        <Grid Width="6" Height="6">
                            <Ellipse
                                Width="6"
                                Height="6"
                                Fill="{ThemeResource ControlStrokeColorSecondaryBrush}" />
                            <Ellipse
                                x:Name="PageDotOneAccent"
                                Width="6"
                                Height="6"
                                Fill="{ThemeResource AccentFillColorDefaultBrush}" />
                        </Grid>
                        <Grid Width="6" Height="6">
                            <Ellipse
                                Width="6"
                                Height="6"
                                Fill="{ThemeResource ControlStrokeColorSecondaryBrush}" />
                            <Ellipse
                                x:Name="PageDotTwoAccent"
                                Width="6"
                                Height="6"
                                Fill="{ThemeResource AccentFillColorDefaultBrush}" />
                        </Grid>
                        <Grid Width="6" Height="6">
                            <Ellipse
                                Width="6"
                                Height="6"
                                Fill="{ThemeResource ControlStrokeColorSecondaryBrush}" />
                            <Ellipse
                                x:Name="PageDotThreeAccent"
                                Width="6"
                                Height="6"
                                Fill="{ThemeResource AccentFillColorDefaultBrush}" />
                        </Grid>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
        <StackPanel x:Name="HeadingGroup" Spacing="8">
            <TextBlock
                Style="{StaticResource TitleTextBlockStyle}"
                Text="Jumping straight to a numbered page"
                TextAlignment="Center"
                TextWrapping="Wrap" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextAlignment="Center"
                TextWrapping="Wrap">
                <Run Text="Hold " />
                <Run Text="{x:Bind ViewModel.FirstModifier, Mode=OneWay}" />
                <Run Text="+" />
                <Run Text="{x:Bind ViewModel.SecondModifier, Mode=OneWay}" />
                <Run Text="+Shift and press a number key. 1 through 9, then 0 for the tenth page, sends the window in focus straight to that page, no matter how far away it is. Drop Shift and the same combo just takes you to that page, leaving the window where it is." />
            </TextBlock>
        </StackPanel>
    </StackPanel>
</UserControl>