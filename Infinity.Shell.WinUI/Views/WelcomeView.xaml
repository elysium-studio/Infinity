<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Infinity.Shell.WinUI.WelcomeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    HorizontalContentAlignment="Center"
    VerticalContentAlignment="Center">
    <Grid>
        <Ellipse
            x:Name="GlowBlobOne"
            Width="360"
            Height="360"
            Margin="-80,-140,0,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Opacity="0.35">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Offset="0.0" Color="#4D2EC4F1" />
                    <GradientStop Offset="1.0" Color="#002EC4F1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
        <Ellipse
            x:Name="GlowBlobTwo"
            Width="320"
            Height="320"
            Margin="120,100,0,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Opacity="0.3">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Offset="0.0" Color="#4D7B5CFF" />
                    <GradientStop Offset="1.0" Color="#007B5CFF" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
        <StackPanel
            MaxWidth="520"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="24">
            <Grid HorizontalAlignment="Center">
                <Image
                    x:Name="LogoImage"
                    Width="112"
                    Height="112"
                    Source="ms-appx:///Assets/Infinity.png" />
                <Border
                    x:Name="ShimmerHost"
                    Width="112"
                    Height="112" />
            </Grid>
            <StackPanel Spacing="8">
                <TextBlock
                    x:Name="HeadingText"
                    Style="{StaticResource TitleLargeTextBlockStyle}"
                    Text="Welcome to Infinity"
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
                <TextBlock
                    x:Name="BodyText"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Infinity turns your desktop into an endless, scrollable canvas of pages. This quick walkthrough covers the basics of moving around and customizing how it feels."
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>