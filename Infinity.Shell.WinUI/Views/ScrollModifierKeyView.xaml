<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Infinity.Shell.WinUI.ScrollModifierKeyView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:CommunityToolkit="using:CommunityToolkit.WinUI.Controls"
    xmlns:Shell="using:Infinity.Shell"
    IsTabStop="True"
    Loaded="{x:Bind ViewModel.Activate}"
    Unloaded="{x:Bind ViewModel.Deactivate}">
    <StackPanel Spacing="8">
        <CommunityToolkit:SettingsCard Description="The shortcut used to trigger desktop scrolling" Header="Scroll Shortcut">
            <StackPanel
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8">
                <ItemsControl
                    VerticalAlignment="Center"
                    ItemsSource="{x:Bind ViewModel.Labels, Mode=OneWay}"
                    Visibility="{x:Bind ToLabelsVisibility(ViewModel.Labels.Count), Mode=OneWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="6" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="Shell:ModifierKeyViewModel">
                            <Button
                                Content="{x:Bind Text}"
                                IsHitTestVisible="False"
                                ToolTipService.ToolTip="{x:Bind ToolTip}">
                                <Button.Style>
                                    <Style BasedOn="{StaticResource AccentButtonStyle}" TargetType="Button">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Height" Value="32" />
                                        <Setter Property="Width" Value="32" />
                                        <Setter Property="FontSize" Value="12" />
                                        <Setter Property="FontFamily" Value="{x:Bind FontFamily}" />
                                    </Style>
                                </Button.Style>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind ToHintText(ViewModel.IsRecording, ViewModel.Labels.Count), Mode=OneWay}"
                    Visibility="{x:Bind ToHintVisibility(ViewModel.Labels.Count, ViewModel.IsRecording), Mode=OneWay}" />
                <Button
                    Click="{x:Bind ViewModel.StartRecording}"
                    Content="&#xE70F;"
                    ToolTipService.ToolTip="Edit"
                    Visibility="{x:Bind ToEditVisibility(ViewModel.IsRecording), Mode=OneWay}">
                    <Button.Style>
                        <Style BasedOn="{StaticResource DefaultButtonStyle}" TargetType="Button">
                            <Setter Property="Width" Value="32" />
                            <Setter Property="Height" Value="32" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
                            <Setter Property="FontSize" Value="14" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                        </Style>
                    </Button.Style>
                </Button>
                <Button
                    Click="{x:Bind ViewModel.CancelRecording}"
                    Content="&#xE711;"
                    ToolTipService.ToolTip="Cancel"
                    Visibility="{x:Bind ToRecordingVisibility(ViewModel.IsRecording), Mode=OneWay}">
                    <Button.Style>
                        <Style BasedOn="{StaticResource DefaultButtonStyle}" TargetType="Button">
                            <Setter Property="Width" Value="32" />
                            <Setter Property="Height" Value="32" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
                            <Setter Property="FontSize" Value="14" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                        </Style>
                    </Button.Style>
                </Button>
                <Button
                    Click="{x:Bind ViewModel.SaveRecording}"
                    Content="&#xE73E;"
                    IsEnabled="{x:Bind ViewModel.CanSave, Mode=OneWay}"
                    ToolTipService.ToolTip="Save"
                    Visibility="{x:Bind ToRecordingVisibility(ViewModel.IsRecording), Mode=OneWay}">
                    <Button.Style>
                        <Style BasedOn="{StaticResource DefaultButtonStyle}" TargetType="Button">
                            <Setter Property="Width" Value="32" />
                            <Setter Property="Height" Value="32" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
                            <Setter Property="FontSize" Value="14" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </CommunityToolkit:SettingsCard>
        <InfoBar
            IsClosable="False"
            IsOpen="{x:Bind ViewModel.IsValidationOpen, Mode=OneWay}"
            Message="{x:Bind ViewModel.ValidationMessage, Mode=OneWay}"
            Severity="Warning" />
    </StackPanel>
</UserControl>