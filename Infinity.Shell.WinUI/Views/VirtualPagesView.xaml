<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Infinity.Shell.WinUI.VirtualPagesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:CommunityToolkit="using:CommunityToolkit.WinUI.Controls"
    Loaded="{x:Bind ViewModel.Activate}"
    Unloaded="{x:Bind ViewModel.Deactivate}">
    <CommunityToolkit:SettingsCard Description="Choose how many pages your desktop spans. Set a fixed number or let it grow as you move windows across" Header="Virtual Pages">
        <ComboBox SelectedIndex="{x:Bind ViewModel.Value, Mode=TwoWay}">
            <ComboBoxItem Content="Unlimited" />
            <ComboBoxItem Content="Fixed" />
        </ComboBox>
    </CommunityToolkit:SettingsCard>
</UserControl>