<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Infinity.Shell.WinUI.PageSwitchTriggerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:WinUI="using:Elysium.UI.WinUI"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    HorizontalContentAlignment="Center"
    VerticalContentAlignment="Top"
    DataContext="{WinUI:ViewModel Key=PageSwitchTriggerView}"
    Loaded="{x:Bind ViewModel.Activate}"
    Unloaded="{x:Bind ViewModel.Deactivate}">
    <StackPanel
        MaxWidth="600"
        HorizontalAlignment="Center"
        Spacing="28">
        <Border
            x:Name="HeroCard"
            Height="240"
            HorizontalAlignment="Stretch"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="14">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="28">
                <Grid
                    VerticalAlignment="Center"
                    ColumnSpacing="10"
                    RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="64" />
                        <RowDefinition Height="64" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="64" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="64" />
                    </Grid.ColumnDefinitions>
                    <Grid
                        x:Name="WinKeyCard"
                        Grid.Row="0"
                        Grid.Column="0">
                        <Border
                            Background="{ThemeResource ControlFillColorSecondaryBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                            BorderThickness="1.5"
                            CornerRadius="12" />
                        <Border
                            x:Name="WinKeyAccentOverlay"
                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                            CornerRadius="12"
                            Opacity="0" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                            Text="{x:Bind ViewModel.FirstModifier, Mode=OneWay}" />
                    </Grid>
                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="+" />
                    <Grid
                        x:Name="CtrlKeyCard"
                        Grid.Row="0"
                        Grid.Column="2">
                        <Border
                            Background="{ThemeResource ControlFillColorSecondaryBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                            BorderThickness="1.5"
                            CornerRadius="12" />
                        <Border
                            x:Name="CtrlKeyAccentOverlay"
                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                            CornerRadius="12"
                            Opacity="0" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                            Text="{x:Bind ViewModel.SecondModifier, Mode=OneWay}" />
                    </Grid>
                    <Grid
                        x:Name="LeftArrowKeyCard"
                        Grid.Row="1"
                        Grid.Column="0">
                        <Border
                            Background="{ThemeResource ControlFillColorSecondaryBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                            BorderThickness="1.5"
                            CornerRadius="12" />
                        <Border
                            x:Name="LeftArrowAccentOverlay"
                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                            CornerRadius="12"
                            Opacity="0" />
                        <FontIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                            FontSize="18"
                            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                            Glyph="&#xF0B0;" />
                    </Grid>
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="or" />
                    <Grid
                        x:Name="RightArrowKeyCard"
                        Grid.Row="1"
                        Grid.Column="2">
                        <Border
                            Background="{ThemeResource ControlFillColorSecondaryBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                            BorderThickness="1.5"
                            CornerRadius="12" />
                        <Border
                            x:Name="RightArrowAccentOverlay"
                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                            CornerRadius="12"
                            Opacity="0" />
                        <FontIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                            FontSize="18"
                            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                            Glyph="&#xF0AF;" />
                    </Grid>
                </Grid>
                <Border
                    Width="1"
                    Height="140"
                    VerticalAlignment="Center"
                    Background="{ThemeResource ControlStrokeColorSecondaryBrush}"
                    Opacity="0.6" />
                <Grid
                    x:Name="JumpStage"
                    Width="200"
                    Height="92"
                    VerticalAlignment="Center">
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Orientation="Horizontal"
                        Spacing="8">
                        <Border
                            Width="90"
                            Height="70"
                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                            BorderThickness="1"
                            CornerRadius="10" />
                        <Border
                            Width="90"
                            Height="70"
                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                            BorderThickness="1"
                            CornerRadius="10" />
                    </StackPanel>
                    <Border
                        x:Name="JumpWindow"
                        Width="64"
                        Height="44"
                        Margin="20,14,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                        BorderThickness="1.5"
                        CornerRadius="8">
                        <Border
                            Height="14"
                            VerticalAlignment="Top"
                            Background="{ThemeResource ControlStrokeColorSecondaryBrush}"
                            CornerRadius="8,8,0,0"
                            Opacity="0.55" />
                    </Border>
                    <Border
                        x:Name="ViewportFrame"
                        Width="98"
                        Height="78"
                        Margin="2,-4,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                        BorderThickness="2"
                        CornerRadius="12" />
                    <StackPanel
                        Margin="0,0,0,2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Orientation="Horizontal"
                        Spacing="6">
                        <Grid Width="6" Height="6">
                            <Ellipse
                                Width="6"
                                Height="6"
                                Fill="{ThemeResource ControlStrokeColorSecondaryBrush}" />
                            <Ellipse
                                x:Name="PageDotOneAccent"
                                Width="6"
                                Height="6"
                                Fill="{ThemeResource AccentFillColorDefaultBrush}" />
                        </Grid>
                        <Grid Width="6" Height="6">
                            <Ellipse
                                Width="6"
                                Height="6"
                                Fill="{ThemeResource ControlStrokeColorSecondaryBrush}" />
                            <Ellipse
                                x:Name="PageDotTwoAccent"
                                Width="6"
                                Height="6"
                                Fill="{ThemeResource AccentFillColorDefaultBrush}" />
                        </Grid>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
        <StackPanel x:Name="HeadingGroup" Spacing="8">
            <TextBlock
                Style="{StaticResource TitleTextBlockStyle}"
                Text="Switching pages without moving anything"
                TextAlignment="Center"
                TextWrapping="Wrap" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextAlignment="Center"
                TextWrapping="Wrap">
                <Run Text="Hold " />
                <Run Text="{x:Bind ViewModel.FirstModifier, Mode=OneWay}" />
                <Run Text="+" />
                <Run Text="{x:Bind ViewModel.SecondModifier, Mode=OneWay}" />
                <Run Text=" and press the Left or Right arrow key, with no other key. The view pans to the next page, but every window — including the one in focus — stays exactly where you left it." />
            </TextBlock>
        </StackPanel>
    </StackPanel>
</UserControl>